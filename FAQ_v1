.flow-step{display:flex;gap:20px;position:relative}
.flow-step:not(:last-child)::after{content:'';position:absolute;left:23px;top:50px;bottom:-4px;width:2px;background:var(--blue-lt)}
.flow-circle{width:46px;height:46px;border-radius:50%;background:var(--blue);color:#fff;font-size:18px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;position:relative;z-index:1}
.flow-body{padding-bottom:32px;flex:1}
.flow-body h3{font-size:18px;font-weight:800;letter-spacing:-.4px;margin-bottom:8px;color:var(--navy)}
.flow-body p{font-size:14px;color:var(--gray);line-height:1.75}
.flow-card{margin-top:14px;background:var(--blue-lt);border-radius:12px;padding:16px 18px}
.flow-card p{font-size:13px;color:var(--blue);line-height:1.7}
.flow-warn{margin-top:14px;background:#FFF2F0;border-radius:12px;padding:14px 18px;font-size:13px;color:#C0392B;line-height:1.7}

/* PHONE MOCKUP */
.mockup-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start}
.phone-mockup{background:var(--navy);border-radius:36px;padding:16px;box-shadow:0 8px 40px rgba(13,27,53,.25)}
.phone-screen{background:var(--bg);border-radius:24px;overflow:hidden}
.phone-topbar{background:var(--blue);padding:14px 16px;display:flex;align-items:center;gap:8px}
.phone-topbar img{height:18px}
.phone-topbar span{color:#fff;font-size:13px;font-weight:700}
.phone-content{padding:20px 16px}
.phone-field{background:var(--white);border-radius:10px;padding:12px 14px;margin-bottom:8px;font-size:13px;color:var(--gray);border:1px solid var(--border)}
.phone-field strong{display:block;font-size:11px;color:var(--blue);font-weight:700;margin-bottom:3px}
.phone-btn{background:var(--blue);color:#fff;border-radius:10px;padding:14px;text-align:center;font-size:14px;font-weight:800;margin-top:12px}
.phone-label{text-align:center;font-size:12px;color:var(--gray-lt);margin-top:10px}
.mockup-text h3{font-size:20px;font-weight:800;letter-spacing:-.5px;margin-bottom:10px}
.mockup-text p{font-size:14px;color:var(--gray);line-height:1.75;margin-bottom:16px}
.check-list{list-style:none;display:flex;flex-direction:column;gap:8px}
.check-list li{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:var(--navy)}
.check-list li::before{content:'✓';width:20px;height:20px;background:var(--blue);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;margin-top:1px}

/* CTA */
.cta-box{background:linear-gradient(135deg,#0D1B35,#1a3a7e);border-radius:20px;padding:48px 40px;text-align:center;margin:48px 0}
.cta-box h3{font-size:24px;font-weight:900;color:#fff;letter-spacing:-.8px;margin-bottom:10px}
.cta-box p{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:28px}
.cta-btns{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.btn-kakao{display:inline-flex;align-items:center;gap:8px;background:var(--kakao);color:var(--kakao-txt);font-size:15px;font-weight:800;padding:14px 28px;border-radius:14px;text-decoration:none}
.btn-phone{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.3);color:#fff;font-size:15px;font-weight:700;padding:14px 28px;border-radius:14px;text-decoration:none}
.cta-note{font-size:12px;color:rgba(255,255,255,.4);margin-top:14px}

/* CAUTION */
.caution-list{display:flex;flex-direction:column;gap:10px}
.caution-item{display:flex;gap:14px;align-items:flex-start;background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:18px 20px}
.caution-num{width:28px;height:28px;border-radius:50%;background:#FFF2F0;color:#C0392B;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.caution-txt{font-size:14px;color:var(--navy);line-height:1.7}
.caution-txt span{color:var(--gray);font-size:13px;display:block;margin-top:3px}

footer{background:var(--bg);border-top:1px solid var(--border);padding:28px 40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.foot-logo img{height:24px}
.foot-info{font-size:12px;color:var(--gray-lt);line-height:1.8;text-align:right}

@media(max-width:700px){
  nav{padding:0 20px}
  .page-hero{padding:48px 20px}
  .who-cards{grid-template-columns:1fr}
  .mockup-row{grid-template-columns:1fr}

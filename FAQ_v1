<title>광고비 적립·출금 방법 | 아정당자동차</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#145CE6;--blue-dk:#0c3db0;--blue-lt:#EEF4FF;--blue-md:#C8DCFF;
  --navy:#0D1B35;--gray:#697077;--gray-lt:#A2A9B0;
  --border:#E2E8F0;--bg:#F0F5FB;--white:#fff;
  --kakao:#FAE300;--kakao-txt:#1A1200;
  --green:#12B76A;--green-lt:#ECFDF3;
  --r:16px;--shadow:0 4px 24px rgba(20,92,230,.10)
}
html{scroll-behavior:smooth}
body{font-family:-apple-system,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:var(--white);color:var(--navy);-webkit-font-smoothing:antialiased}

nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.92);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:64px;display:flex;align-items:center;padding:0 40px;justify-content:space-between;gap:12px}
.nav-left{display:flex;align-items:center;gap:16px}
.nav-back{display:inline-flex;align-items:center;gap:6px;font-size:14px;color:var(--gray);text-decoration:none;font-weight:500;transition:color .18s}
.nav-back:hover{color:var(--blue)}
.nav-logo img{height:28px}
.nav-kakao{background:var(--kakao);color:var(--kakao-txt);font-size:14px;font-weight:700;padding:9px 20px;border-radius:999px;text-decoration:none}

/* HERO */
.page-hero{background:linear-gradient(135deg,#deeaff 0%,#f0f5fb 100%);padding:64px 40px;text-align:center;position:relative;overflow:hidden}
.page-tag{display:inline-flex;align-items:center;gap:6px;background:var(--blue);color:#fff;font-size:12px;font-weight:700;padding:6px 16px;border-radius:999px;margin-bottom:16px}
.page-hero h1{font-size:clamp(28px,4vw,46px);font-weight:900;letter-spacing:-1.5px;line-height:1.2;margin-bottom:12px}
.page-hero p{font-size:16px;color:var(--gray);margin-bottom:28px}
.badge-row{display:flex;justify-content:center;gap:10px;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;gap:6px;background:var(--white);border:1.5px solid var(--border);border-radius:999px;padding:8px 18px;font-size:14px;font-weight:700;color:var(--navy)}
.b-blue{color:var(--blue)}
.b-green{color:var(--green)}

/* LAYOUT */
.wrap{max-width:800px;margin:0 auto;padding:0 24px}
.section{padding:64px 24px}
.section.gray{background:var(--bg)}
.sec-label{font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:10px}
.sec-title{font-size:clamp(22px,3vw,34px);font-weight:900;letter-spacing:-1px;margin-bottom:10px}
.sec-sub{font-size:15px;color:var(--gray);margin-bottom:32px;line-height:1.7}

/* TIMELINE - 적립 흐름 */
.timeline{display:flex;gap:0;align-items:stretch;margin-bottom:32px}
.tl-item{flex:1;display:flex;flex-direction:column;align-items:center;position:relative}
.tl-item:not(:last-child)::after{content:'→';position:absolute;right:-12px;top:28px;font-size:20px;color:var(--blue-md);font-weight:900;z-index:1}
.tl-circle{width:56px;height:56px;border-radius:50%;background:var(--blue);color:#fff;font-size:22px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;box-shadow:0 4px 16px rgba(20,92,230,.25)}
.tl-label{font-size:13px;font-weight:800;color:var(--navy);text-align:center;margin-bottom:4px}
.tl-sub{font-size:11.5px;color:var(--gray);text-align:center;line-height:1.5}

/* BIG STATS */
.big-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:40px}
.bs-card{border-radius:var(--r);padding:28px 20px;text-align:center;border:1.5px solid var(--border);background:var(--white);transition:box-shadow .2s}
.bs-card:hover{box-shadow:var(--shadow)}
.bs-card.highlight{background:var(--blue);border-color:var(--blue);color:white}
.bs-icon{font-size:32px;margin-bottom:12px;display:block}
.bs-num{font-size:36px;font-weight:900;letter-spacing:-1px;line-height:1;margin-bottom:6px;color:var(--navy)}
.bs-card.highlight .bs-num{color:#fff}
.bs-num .u{font-size:20px;color:var(--blue)}
.bs-card.highlight .bs-num .u{color:var(--kakao)}
.bs-desc{font-size:12.5px;color:var(--gray);line-height:1.6}
.bs-card.highlight .bs-desc{color:rgba(255,255,255,.75)}

/* 출금 단계 */
.withdraw-steps{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px}
.ws-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:24px;transition:box-shadow .2s,border-color .2s}
.ws-card:hover{border-color:var(--blue-md);box-shadow:var(--shadow)}
.ws-step-badge{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:50%;background:var(--blue);color:#fff;font-size:13px;font-weight:800;margin-bottom:14px}
.ws-title{font-size:16px;font-weight:800;color:var(--navy);margin-bottom:6px}
.ws-desc{font-size:13.5px;color:var(--gray);line-height:1.7}
.ws-tip{margin-top:10px;padding:10px 13px;background:var(--blue-lt);border-radius:10px;font-size:12.5px;color:var(--blue);line-height:1.6}

/* 타임라인 출금 시간 */
.time-cards{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px}
.time-card{border-radius:var(--r);padding:24px;display:flex;gap:16px;align-items:flex-start}
.time-card.day{background:var(--green-lt);border:1.5px solid #A7F3D0}
.time-card.next{background:var(--bg);border:1.5px solid var(--border)}
.time-icon{font-size:32px;flex-shrink:0}
.time-label{font-size:12px;font-weight:800;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
.time-card.day .time-label{color:var(--green)}
.time-card.next .time-label{color:var(--gray)}
.time-title{font-size:18px;font-weight:900;letter-spacing:-.5px;margin-bottom:4px}
.time-card.day .time-title{color:#065F46}
.time-desc{font-size:13px;color:var(--gray);line-height:1.5}

/* 앱 화면 */
.app-screen-row{display:grid;grid-template-columns:240px 1fr;gap:32px;align-items:center}
.phone-wrap{background:var(--navy);border-radius:36px;padding:14px;box-shadow:0 8px 40px rgba(13,27,53,.25)}
.phone-inner{background:var(--bg);border-radius:26px;overflow:hidden}
.p-bar{background:var(--blue);padding:12px 16px;display:flex;align-items:center;gap:8px}
.p-bar img{height:16px}
.p-bar span{color:#fff;font-size:12px;font-weight:700}
.p-body{padding:16px}
.p-balance{background:var(--blue);border-radius:12px;padding:16px;text-align:center;margin-bottom:10px}
.p-balance .pb-label{font-size:10px;color:rgba(255,255,255,.7);margin-bottom:4px}
.p-balance .pb-amount{font-size:24px;font-weight:900;color:#fff;letter-spacing:-1px}
.p-balance .pb-sub{font-size:10px;color:var(--kakao);margin-top:2px}
.p-row{display:flex;justify-content:space-between;align-items:center;background:var(--white);border-radius:10px;padding:10px 12px;margin-bottom:6px;font-size:12px}
.p-row .pr-label{color:var(--gray)}
.p-row .pr-val{font-weight:700;color:var(--navy)}
.p-btn{background:var(--blue);color:#fff;border-radius:10px;padding:12px;text-align:center;font-size:13px;font-weight:800;margin-top:8px}
.screen-desc h3{font-size:20px;font-weight:800;letter-spacing:-.5px;margin-bottom:12px}
.screen-desc p{font-size:14px;color:var(--gray);line-height:1.75;margin-bottom:16px}
.info-box{padding:14px 18px;border-radius:12px;font-size:13px;line-height:1.7;margin-bottom:10px}
.info-box.blue{background:var(--blue-lt);color:var(--blue)}
.info-box.warn{background:#FFF2F0;color:#C0392B}
.info-box.green{background:var(--green-lt);color:#065F46}

/* 주의사항 */
.caution-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.caution-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:20px}
.cc-icon{font-size:28px;margin-bottom:10px;display:block}
.cc-title{font-size:14px;font-weight:800;color:var(--navy);margin-bottom:5px}
.cc-desc{font-size:13px;color:var(--gray);line-height:1.6}

/* CTA */
.cta-box{background:linear-gradient(135deg,#0D1B35,#1a3a7e);border-radius:20px;padding:48px 40px;text-align:center;margin-top:48px}
.cta-box h3{font-size:24px;font-weight:900;color:#fff;letter-spacing:-.8px;margin-bottom:10px}
.cta-box p{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:28px}
.cta-btns{display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.btn-kakao{display:inline-flex;align-items:center;gap:8px;background:var(--kakao);color:var(--kakao-txt);font-size:15px;font-weight:800;padding:14px 28px;border-radius:14px;text-decoration:none}
.btn-phone{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.3);color:#fff;font-size:15px;font-weight:700;padding:14px 28px;border-radius:14px;text-decoration:none}
.cta-note{font-size:12px;color:rgba(255,255,255,.4);margin-top:14px}

footer{background:var(--bg);border-top:1px solid var(--border);padding:28px 40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px}
.foot-logo img{height:24px}
.foot-info{font-size:12px;color:var(--gray-lt);line-height:1.8;text-align:right}

@media(max-width:700px){
  nav{padding:0 20px}
  .page-hero{padding:48px 20px}
  .big-stats{grid-template-columns:1fr 1fr}
  .withdraw-steps,.time-cards,.caution-grid{grid-template-columns:1fr}
  .app-screen-row{grid-template-columns:1fr}
  .cta-box{padding:36px 24px}
  footer{flex-direction:column;align-items:flex-start;padding:24px 20px}
  .foot-info{text-align:left}
}
</style>
</head>

<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>아정당자동차 FAQ</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#145CE6;--blue-dk:#0c3db0;--blue-lt:#EEF4FF;--blue-md:#C8DCFF;
  --navy:#0D1B35;--gray:#697077;--gray-lt:#A2A9B0;--border:#E2E8F0;
  --bg:#F0F5FB;--white:#fff;--kakao:#FAE300;--kakao-txt:#1A1200;
  --r:16px;--shadow:0 4px 24px rgba(20,92,230,.10);
}
html{scroll-behavior:smooth}
body{font-family:-apple-system,'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:var(--white);color:var(--navy);-webkit-font-smoothing:antialiased;padding-bottom:80px}

/* ── NAV ── */
nav{position:sticky;top:0;z-index:200;background:rgba(255,255,255,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);height:64px;display:flex;align-items:center;padding:0 40px;justify-content:space-between}
.nav-logo{display:flex;align-items:center}
.nav-logo img{height:30px;display:block}
.nav-links{display:flex;gap:28px;list-style:none}
.nav-links a{font-size:14px;color:var(--gray);text-decoration:none;font-weight:500;transition:color .18s}
.nav-links a:hover{color:var(--blue)}
.nav-kakao{background:var(--kakao);color:var(--kakao-txt);font-size:14px;font-weight:700;padding:9px 20px;border-radius:999px;text-decoration:none;transition:opacity .18s;white-space:nowrap}
.nav-kakao:hover{opacity:.88}

/* ── HERO ── */
.hero{
  background:linear-gradient(160deg,#d6e8ff 0%,#eaf2ff 45%,#f4f8ff 100%);
  display:grid;
  grid-template-columns:1fr 400px;
  align-items:flex-end;
  min-height:580px;
  overflow:hidden;
  position:relative;
}
.hero-content{
  padding:72px 40px 72px 60px;
  position:relative;z-index:2;
  display:flex;flex-direction:column;align-items:flex-start;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--blue);color:#fff;
  font-size:12px;font-weight:700;padding:6px 16px;border-radius:999px;
  margin-bottom:20px;letter-spacing:.3px;
}
.hero h1{
  font-size:clamp(32px,4vw,52px);font-weight:900;
  letter-spacing:-1.5px;line-height:1.15;
  color:var(--navy);margin-bottom:20px;
}
.hero h1 .hl{color:var(--blue)}
.hero-checks{list-style:none;display:flex;flex-direction:column;gap:11px;margin-bottom:32px}
.hero-checks li{display:flex;align-items:center;gap:10px;font-size:15px;color:var(--navy);font-weight:500}
.hero-checks li::before{
  content:'✓';width:22px;height:22px;background:var(--blue);color:#fff;
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:800;flex-shrink:0;
}
.hero-btns{display:flex;flex-direction:column;gap:10px;width:100%;max-width:360px}
.btn-kakao-hero{
  display:flex;align-items:center;justify-content:center;gap:8px;
  background:var(--kakao);color:var(--kakao-txt);
  font-size:16px;font-weight:800;padding:16px 24px;border-radius:14px;
  text-decoration:none;transition:opacity .18s,transform .18s;
}
.btn-kakao-hero:hover{opacity:.9;transform:translateY(-1px)}
.btn-app-install{
  display:flex;align-items:center;justify-content:center;gap:8px;
  background:var(--blue);color:#fff;
  font-size:16px;font-weight:800;padding:16px 24px;border-radius:14px;
  text-decoration:none;transition:opacity .18s,transform .18s;
}
.btn-app-install:hover{opacity:.9;transform:translateY(-1px)}
.btn-guide{
  display:flex;align-items:center;justify-content:center;gap:8px;
  background:var(--navy);color:#fff;
  font-size:15px;font-weight:700;padding:14px 24px;border-radius:14px;
  text-decoration:none;transition:opacity .18s,transform .18s;
}
.btn-guide:hover{opacity:.9;transform:translateY(-1px)}

/* hero 모델 영역 */
.hero-model-wrap{
  position:relative;align-self:flex-end;
  height:100%;min-height:480px;
  display:flex;align-items:flex-end;justify-content:center;
}
.hero-model-wrap img.model-img{
  width:100%;max-width:380px;display:block;
  filter:drop-shadow(0 8px 32px rgba(20,92,230,.18));
  position:relative;z-index:1;
}
.bubble{
  position:absolute;z-index:2;
  border-radius:14px;padding:12px 18px;
  font-weight:800;font-size:14px;
  box-shadow:0 4px 20px rgba(0,0,0,.12);
}
.bubble.left{
  left:-30px;bottom:200px;
  background:var(--navy);color:#fff;
}
.bubble.right{
  right:-20px;bottom:280px;
  background:var(--white);color:var(--navy);
  border:2px solid var(--blue-md);
}
.bubble .b-num{font-size:22px;font-weight:900;color:var(--kakao);display:block;line-height:1}
.bubble.right .b-num{color:var(--blue)}
.bubble .b-lbl{font-size:11px;color:rgba(255,255,255,.65);font-weight:500}
.bubble.right .b-lbl{color:var(--gray)}

/* ── STATS BAR ── */
.stats-bar{background:var(--blue);display:grid;grid-template-columns:repeat(4,1fr)}
.stat-item{
  padding:22px 20px;border-right:1px solid rgba(255,255,255,.15);
  text-align:center;
}
.stat-item:last-child{border-right:none}
.s-num{
  font-size:38px;font-weight:900;color:#fff;
  letter-spacing:-1px;line-height:1;margin-bottom:5px;
}
/* 단위 - 숫자 단위는 작고 반투명, 한글은 전부 흰색 굵게 */
.s-num .unit-small{font-size:20px;color:rgba(255,255,255,.75)}
.s-lbl{font-size:12px;color:rgba(255,255,255,.7)}

/* ── 공통 섹션 ── */
.section{padding:80px 0}
.section.gray{background:var(--bg)}
.wrap{max-width:1060px;margin:0 auto;padding:0 40px}
.eyebrow{font-size:12px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--blue);margin-bottom:10px}
.sec-title{font-size:clamp(26px,3.5vw,40px);font-weight:900;letter-spacing:-1.2px;line-height:1.2;margin-bottom:10px}
.sec-sub{font-size:15px;color:var(--gray);margin-bottom:44px;line-height:1.7}

/* ── APP GUIDE ── */
.steps{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:40px}
.step-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);overflow:hidden;transition:box-shadow .2s,border-color .2s}
.step-card:hover{border-color:var(--blue-md);box-shadow:var(--shadow)}
.step-img{height:160px;display:flex;align-items:center;justify-content:center;font-size:60px;position:relative}
.step-img .sn{position:absolute;top:12px;left:12px;background:var(--blue);color:#fff;font-size:11px;font-weight:800;padding:3px 10px;border-radius:999px;letter-spacing:1px}
.step-body{padding:20px}
.step-title{font-size:15px;font-weight:800;letter-spacing:-.3px;margin-bottom:6px;color:var(--navy)}
.step-desc{font-size:13px;color:var(--gray);line-height:1.7}
.step-tip{margin-top:10px;padding:9px 12px;background:var(--blue-lt);border-radius:8px;font-size:12px;color:var(--blue);line-height:1.6}
.step-warn{margin-top:10px;padding:9px 12px;background:#FFF2F0;border-radius:8px;font-size:12px;color:#C0392B;line-height:1.6}

/* 앱 기능 4개 */
.feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.feat-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r);padding:24px 18px;transition:box-shadow .2s}
.feat-card:hover{box-shadow:var(--shadow)}
.feat-icon{font-size:28px;margin-bottom:10px}
.feat-title{font-size:14px;font-weight:700;margin-bottom:5px;color:var(--navy)}
.feat-desc{font-size:12.5px;color:var(--gray);line-height:1.6}

/* ── 카테고리 카드 ── */
.cat-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.cat-card{
  background:var(--white);border:1.5px solid var(--border);
  border-radius:20px;padding:32px;
  display:flex;gap:20px;align-items:flex-start;
  transition:box-shadow .2s,border-color .2s;
}
.cat-card:hover{border-color:var(--blue-md);box-shadow:var(--shadow)}
.cat-icon-wrap{width:64px;height:64px;border-radius:16px;background:var(--blue-lt);display:flex;align-items:center;justify-content:center;font-size:32px;flex-shrink:0}
.cat-body{flex:1}
.cat-title{font-size:18px;font-weight:800;letter-spacing:-.4px;margin-bottom:6px;color:var(--navy)}
.cat-desc{font-size:13.5px;color:var(--gray);line-height:1.7;margin-bottom:16px}
.cat-badge{display:inline-block;background:#E8F0FF;color:var(--blue);font-size:12px;font-weight:700;padding:4px 12px;border-radius:999px;margin-bottom:12px}
.btn-detail{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--blue);color:#fff;font-size:13px;font-weight:700;
  padding:10px 20px;border-radius:999px;text-decoration:none;transition:background .18s;
}
.btn-detail:hover{background:var(--blue-dk)}

/* ── FAQ ── */
.faq-cat{font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--gray-lt);padding-bottom:8px;margin-bottom:4px;border-bottom:1px solid var(--border);margin-top:32px}
.faq-cat:first-of-type{margin-top:0}
.faq-item{border-bottom:1px solid var(--border)}
.faq-btn{width:100%;background:none;border:none;display:flex;justify-content:space-between;align-items:center;gap:16px;padding:20px 0;cursor:pointer;font-family:inherit;text-align:left}
.faq-btn:hover .fq-txt{color:var(--blue)}
.fq-txt{font-size:15px;font-weight:600;letter-spacing:-.3px;color:var(--navy);transition:color .18s;flex:1}
.fq-ic{width:26px;height:26px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--gray);flex-shrink:0;transition:all .25s;font-style:normal}
.faq-item.open .fq-ic{background:var(--blue);border-color:var(--blue);color:#fff;transform:rotate(45deg)}
.faq-ans{display:none;padding:0 0 20px;font-size:14px;color:var(--gray);line-height:1.85}
.faq-item.open .faq-ans{display:block}
.faq-ans ol,.faq-ans ul{padding-left:18px}
.faq-ans li{margin-bottom:6px}
.faq-ans strong{color:var(--navy)}
.abox{margin-top:12px;padding:12px 16px;border-radius:10px;font-size:13px;line-height:1.7}
.abox.info{background:var(--blue-lt);color:var(--blue)}
.abox.warn{background:#FFF2F0;color:#C0392B}
.abox.gold{background:#FFFBE0;color:#7A5800}

/* ── 매니저 CS 섹션 ── */
.cs-section{
  background:linear-gradient(135deg,#0D1B35 0%,#1a3a7e 100%);
  border-radius:24px;padding:52px 52px;
  display:grid;grid-template-columns:1fr 1fr;
  gap:40px;align-items:center;
}
.cs-img-wrap{
  display:flex;align-items:center;justify-content:center;
}
.cs-img-wrap img{
  width:100%;max-width:340px;
  display:block;
}
.cs-text h3{font-size:28px;font-weight:900;letter-spacing:-1px;color:#fff;margin-bottom:8px}
.cs-text p{font-size:15px;color:rgba(255,255,255,.72);margin-bottom:28px;line-height:1.7}
.cs-btns{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px}
.cs-btn-kakao{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--kakao);color:var(--kakao-txt);
  font-size:15px;font-weight:800;padding:14px 24px;border-radius:14px;
  text-decoration:none;transition:opacity .18s;
}
.cs-btn-kakao:hover{opacity:.9}
.cs-btn-phone{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(255,255,255,.13);border:1.5px solid rgba(255,255,255,.28);color:#fff;
  font-size:15px;font-weight:700;padding:14px 24px;border-radius:14px;
  text-decoration:none;transition:background .18s;
}
.cs-btn-phone:hover{background:rgba(255,255,255,.22)}
.cs-btn-app{
  display:inline-flex;align-items:center;gap:8px;
  background:var(--blue);border:1.5px solid rgba(255,255,255,.2);color:#fff;
  font-size:15px;font-weight:700;padding:14px 24px;border-radius:14px;
  text-decoration:none;transition:opacity .18s;
  width:100%;justify-content:center;margin-top:4px;
}
.cs-btn-app:hover{opacity:.88}
.cs-note{font-size:12px;color:rgba(255,255,255,.4);margin-top:10px}

/* ── FOOTER ── */
footer{background:var(--bg);border-top:1px solid var(--border);padding:32px 40px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px}
.foot-logo img{height:26px;display:block}
.foot-info{font-size:12px;color:var(--gray-lt);line-height:1.8;text-align:right}

/* ── 고정 하단 바 ── */
.fixed-bar{
  position:fixed;bottom:0;left:0;right:0;
  z-index:300;
  background:transparent;
  padding:12px 24px 16px;
  display:flex;gap:10px;align-items:center;
  justify-content:center;
  pointer-events:none;
}
.fixed-bar a{pointer-events:auto}
.fixed-bar .fb-kakao{
  display:flex;align-items:center;justify-content:center;gap:7px;
  background:var(--kakao);color:var(--kakao-txt);
  font-size:15px;font-weight:800;padding:13px 28px;border-radius:12px;
  text-decoration:none;flex:1;max-width:260px;
  transition:opacity .18s;
}
.fixed-bar .fb-kakao:hover{opacity:.9}
.fixed-bar .fb-app{
  display:flex;align-items:center;justify-content:center;gap:7px;
  background:var(--blue);color:#fff;
  font-size:15px;font-weight:800;padding:13px 28px;border-radius:12px;
  text-decoration:none;flex:1;max-width:260px;
  transition:opacity .18s;
}
.fixed-bar .fb-app:hover{opacity:.9}

/* ── RESPONSIVE ── */
@media(max-width:1000px){
  .hero{grid-template-columns:1fr 320px}
  .steps{grid-template-columns:1fr 1fr}
  .feat-grid{grid-template-columns:1fr 1fr}
  .cat-cards{grid-template-columns:1fr}
  .cs-section{grid-template-columns:1fr;padding:40px 32px;text-align:center}
  .cs-img-wrap img{max-width:200px;margin:0 auto}
  .cs-btns{justify-content:center}
}
@media(max-width:700px){
  nav{padding:0 16px}
  .nav-links{display:none}
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero-content{padding:52px 20px 24px}
  .hero-model-wrap{min-height:280px}
  .hero-model-wrap img.model-img{max-width:260px}
  .hero-btns{max-width:100%}
  .section{padding:52px 0}
  .wrap{padding:0 20px}
  .stats-bar{grid-template-columns:repeat(2,1fr)}
  .steps{grid-template-columns:1fr}
  .feat-grid{grid-template-columns:1fr 1fr}
  .cs-section{padding:36px 20px}
  footer{padding:24px 20px;flex-direction:column;align-items:flex-start}
  .foot-info{text-align:left}
  .fixed-bar{padding:10px 12px;gap:8px}
  .fixed-bar .fb-kakao,.fixed-bar .fb-app{font-size:13px;padding:11px 16px}
}
</style>
</head>

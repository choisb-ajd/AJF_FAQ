# 구글 서비스 계정 (Google Cloud Console에서 발급받은 JSON 키 파일 안의 값)
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxx@xxxx.iam.gserviceaccount.com
# private_key 값을 그대로 복사하세요. 줄바꿈은 \n 으로 들어가 있어도 됩니다.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# 관리자용 종합 스프레드시트 ID (URL의 /d/ 와 /edit 사이 문자열)
ADMIN_SPREADSHEET_ID=1QYmS11e-oUON1RwXIh8RgLYAQKC6Ev6Ge3Rz6nps40k

# 로그인 세션을 암호화하는 데 쓰는 임의의 긴 문자열 (아무 문자열이나 길게 입력하면 됩니다)
JWT_SECRET=change-this-to-a-very-long-random-string
